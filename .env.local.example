# Copy this file to .env.local and fill in real values.
# Required for the homepage contact form to actually send emails.
#
# CONTACT_EMAIL_USER: the Gmail address that will send the message
#   (it can be the same as the recipient, colocadoandrewed@gmail.com).
# CONTACT_EMAIL_APP_PASSWORD: a Gmail "App Password" for that account —
#   NOT the regular Gmail login password. Generate one at
#   https://myaccount.google.com/apppasswords (requires 2-Step
#   Verification to be turned on first).

CONTACT_EMAIL_USER=colocadoandrewed@gmail.com
CONTACT_EMAIL_APP_PASSWORD=your-16-character-app-password
