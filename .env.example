# Copy this file to .env.local and fill in your own key.
# Get a free key (no credit card required) at https://console.groq.com/keys
# Without this set, the Andrew AI assistant automatically falls back to its
# built-in rule-based responses — the site works fine either way.
GROQ_API_KEY=

# Google Places API (New) key, used to show real Google Maps reviews on
# destination and food detail pages. Requires a Google Cloud project with
# "Places API (New)" enabled and billing turned on (Google gives a recurring
# monthly credit that comfortably covers small, low-traffic use, and reviews
# are cached for 24h to keep request volume low).
# Without this set, the Google Reviews section is simply hidden — the site
# works fine either way. Get a key at https://console.cloud.google.com/apis/credentials
GOOGLE_PLACES_API_KEY=
